            "path": "/Users/singamshiva78_gmail.com#ext#@singamshiva78gmail.onmicrosoft.com/.bundle/nyc_taxi/dev/resources/[dev singamshiva78_gmail_com_ext] NYC_TAXI_DATA DASHBOARD.lvdash.json",
            "provider_config": [],
            "serialized_dashboard": "{\n  \"datasets\": [\n    {\n      \"name\": \"6b29efba\",\n      \"displayName\": \"Summary of New York City Taxi Trip Metrics\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    COUNT(*) AS total_trips,\\r\\n\",\n        \"    ROUND(SUM(total_amount), 2) AS total_revenue,\\r\\n\",\n        \"    ROUND(AVG(trip_duration_mins), 2) AS avg_trip_duration,\\r\\n\",\n        \"    ROUND(AVG(tip_percentage), 2) AS avg_tip_pct\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"8cdeb6f5\",\n      \"displayName\": \"Taxi Trip Counts by Pickup Hour Category\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    pickup_hour_category,\\r\\n\",\n        \"    COUNT(*) AS trips\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"GROUP BY pickup_hour_category\\r\\n\",\n        \"ORDER BY trips DESC;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"43fa2edb\",\n      \"displayName\": \"Hourly Taxi Ride Totals by Pickup Time\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    pickup_hour,\\r\\n\",\n        \"    COUNT(*) AS trips\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"GROUP BY pickup_hour\\r\\n\",\n        \"ORDER BY pickup_hour;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"73fe762a\",\n      \"displayName\": \"Taxi Payment Category Revenue Summary\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    payment_category,\\r\\n\",\n        \"    ROUND(SUM(total_amount), 2) AS revenue\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"GROUP BY payment_category;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"68f1eb9a\",\n      \"displayName\": \"Taxi Trip Distance Summary by Category\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    trip_distance_category,\\r\\n\",\n        \"    COUNT(*) AS trips\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"GROUP BY trip_distance_category;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"f9e3ba9e\",\n      \"displayName\": \"Average Taxi Cost Per Mile by Distance Category\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    trip_distance_category,\\r\\n\",\n        \"    ROUND(AVG(cost_per_mile), 2) AS avg_cost_per_mile\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"GROUP BY trip_distance_category;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"03c139d1\",\n      \"displayName\": \"Taxi Trip Summary with Duration Amount and Distance Categories\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    trip_duration_mins,\\r\\n\",\n        \"    total_amount,\\r\\n\",\n        \"    trip_distance_category\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"LIMIT 10000;\"\n      ],\n      \"catalog\": \"nyctaxi\",\n      \"schema\": \"taxi_db\"\n    },\n    {\n      \"name\": \"19ea59c9\",\n      \"displayName\": \"Average Taxi Tip Percentage by Payment Method\",\n      \"queryLines\": [\n        \"SELECT \\r\\n\",\n        \"    payment_category,\\r\\n\",\n        \"    ROUND(AVG(tip_percentage), 2) AS avg_tip\\r\\n\",\n        \"FROM nyctaxi.taxi_db.gold_taxi_trips\\r\\n\",\n        \"GROUP BY payment_category;\"\n      ]\n    }\n  ],\n  \"pages\": [\n    {\n      \"name\": \"f6c8a87d\",\n      \"displayName\": \"nyc_taxi_dshboard\",\n      \"layout\": [\n        {\n          \"widget\": {\n            \"name\": \"total-trips\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"6b29efba\",\n                  \"fields\": [\n                    {\n                      \"name\": \"total_trips\",\n                      \"expression\": \"`total_trips`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 2,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Total_trips\"\n              },\n              \"widgetType\": \"counter\",\n              \"encodings\": {\n                \"value\": {\n                  \"fieldName\": \"total_trips\"\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 0,\n            \"y\": 1,\n            \"width\": 3,\n            \"height\": 3\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"total-revenue\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"6b29efba\",\n                  \"fields\": [\n                    {\n                      \"name\": \"total_revenue\",\n                      \"expression\": \"`total_revenue`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 2,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Total_revenue\"\n              },\n              \"widgetType\": \"counter\",\n              \"encodings\": {\n                \"value\": {\n                  \"fieldName\": \"total_revenue\"\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 3,\n            \"y\": 1,\n            \"width\": 3,\n            \"height\": 3\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"avg-tri-p-duration\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"6b29efba\",\n                  \"fields\": [\n                    {\n                      \"name\": \"avg_trip_duration\",\n                      \"expression\": \"`avg_trip_duration`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 2,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Avg_tri[p_duration\"\n              },\n              \"widgetType\": \"counter\",\n              \"encodings\": {\n                \"value\": {\n                  \"fieldName\": \"avg_trip_duration\"\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 6,\n            \"y\": 1,\n            \"width\": 3,\n            \"height\": 3\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"avg-trip\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"6b29efba\",\n                  \"fields\": [\n                    {\n                      \"name\": \"avg_tip_pct\",\n                      \"expression\": \"`avg_tip_pct`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 2,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Avg_trip_pct\"\n              },\n              \"widgetType\": \"counter\",\n              \"encodings\": {\n                \"value\": {\n                  \"fieldName\": \"avg_tip_pct\"\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 9,\n            \"y\": 1,\n            \"width\": 3,\n            \"height\": 3\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"trips-time-day\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"8cdeb6f5\",\n                  \"fields\": [\n                    {\n                      \"name\": \"sum(trips)\",\n                      \"expression\": \"SUM(`trips`)\"\n                    },\n                    {\n                      \"name\": \"pickup_hour_category\",\n                      \"expression\": \"`pickup_hour_category`\"\n                    }\n                  ],\n                  \"disaggregated\": false\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 3,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Trips by Time of Day \"\n              },\n              \"widgetType\": \"bar\",\n              \"encodings\": {\n                \"x\": {\n                  \"fieldName\": \"sum(trips)\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                },\n                \"y\": {\n                  \"fieldName\": \"pickup_hour_category\",\n                  \"scale\": {\n                    \"type\": \"categorical\"\n                  }\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 0,\n            \"y\": 4,\n            \"width\": 6,\n            \"height\": 6\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"trips-by-hour-peak-analysis\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"43fa2edb\",\n                  \"fields\": [\n                    {\n                      \"name\": \"pickup_hour\",\n                      \"expression\": \"`pickup_hour`\"\n                    },\n                    {\n                      \"name\": \"trips\",\n                      \"expression\": \"`trips`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 3,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Trips by Hour (Peak Analysis)\"\n              },\n              \"widgetType\": \"bar\",\n              \"encodings\": {\n                \"x\": {\n                  \"fieldName\": \"pickup_hour\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                },\n                \"y\": {\n                  \"fieldName\": \"trips\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 6,\n            \"y\": 4,\n            \"width\": 6,\n            \"height\": 6\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"revenue-payment-type\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"73fe762a\",\n                  \"fields\": [\n                    {\n                      \"name\": \"sum(revenue)\",\n                      \"expression\": \"SUM(`revenue`)\"\n                    },\n                    {\n                      \"name\": \"payment_category\",\n                      \"expression\": \"`payment_category`\"\n                    }\n                  ],\n                  \"disaggregated\": false\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 3,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Revenue by Payment Type\"\n              },\n              \"widgetType\": \"pie\",\n              \"encodings\": {\n                \"angle\": {\n                  \"fieldName\": \"sum(revenue)\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                },\n                \"color\": {\n                  \"fieldName\": \"payment_category\",\n                  \"scale\": {\n                    \"type\": \"categorical\"\n                  }\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 0,\n            \"y\": 10,\n            \"width\": 6,\n            \"height\": 6\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"trip-distance-distribution\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"68f1eb9a\",\n                  \"fields\": [\n                    {\n                      \"name\": \"trip_distance_category\",\n                      \"expression\": \"`trip_distance_category`\"\n                    },\n                    {\n                      \"name\": \"trips\",\n                      \"expression\": \"`trips`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 3,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Trip Distance Distribution\"\n              },\n              \"widgetType\": \"bar\",\n              \"encodings\": {\n                \"x\": {\n                  \"fieldName\": \"trip_distance_category\",\n                  \"scale\": {\n                    \"type\": \"categorical\"\n                  }\n                },\n                \"y\": {\n                  \"fieldName\": \"trips\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 6,\n            \"y\": 10,\n            \"width\": 6,\n            \"height\": 6\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"cost-efficiency\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"f9e3ba9e\",\n                  \"fields\": [\n                    {\n                      \"name\": \"trip_distance_category\",\n                      \"expression\": \"`trip_distance_category`\"\n                    },\n                    {\n                      \"name\": \"sum(avg_cost_per_mile)\",\n                      \"expression\": \"SUM(`avg_cost_per_mile`)\"\n                    }\n                  ],\n                  \"disaggregated\": false\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 3,\n              \"frame\": {\n                \"showTitle\": true,\n                \"title\": \"Cost Efficiency\"\n              },\n              \"widgetType\": \"bar\",\n              \"encodings\": {\n                \"x\": {\n                  \"fieldName\": \"trip_distance_category\",\n                  \"scale\": {\n                    \"type\": \"categorical\"\n                  }\n                },\n                \"y\": {\n                  \"fieldName\": \"sum(avg_cost_per_mile)\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 0,\n            \"y\": 16,\n            \"width\": 6,\n            \"height\": 6\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"bf680d99\",\n            \"queries\": [\n              {\n                \"name\": \"main_query\",\n                \"query\": {\n                  \"datasetName\": \"03c139d1\",\n                  \"fields\": [\n                    {\n                      \"name\": \"trip_distance_category\",\n                      \"expression\": \"`trip_distance_category`\"\n                    },\n                    {\n                      \"name\": \"trip_duration_mins\",\n                      \"expression\": \"`trip_duration_mins`\"\n                    },\n                    {\n                      \"name\": \"total_amount\",\n                      \"expression\": \"`total_amount`\"\n                    }\n                  ],\n                  \"disaggregated\": true\n                }\n              }\n            ],\n            \"spec\": {\n              \"version\": 3,\n              \"widgetType\": \"scatter\",\n              \"encodings\": {\n                \"x\": {\n                  \"fieldName\": \"trip_duration_mins\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                },\n                \"y\": {\n                  \"fieldName\": \"total_amount\",\n                  \"scale\": {\n                    \"type\": \"quantitative\"\n                  }\n                },\n                \"color\": {\n                  \"fieldName\": \"trip_distance_category\",\n                  \"scale\": {\n                    \"type\": \"categorical\"\n                  }\n                }\n              }\n            }\n          },\n          \"position\": {\n            \"x\": 6,\n            \"y\": 16,\n            \"width\": 6,\n            \"height\": 6\n          }\n        },\n        {\n          \"widget\": {\n            \"name\": \"70854bc0\",\n            \"multilineTextboxSpec\": {\n              \"lines\": [\n                \"NYC Taxi Analytics Dashboard(Data Period: Jan 1 – Jan 30, 2024)\"\n              ]\n            }\n          },\n          \"position\": {\n            \"x\": 0,\n            \"y\": 0,\n            \"width\": 12,\n            \"height\": 1\n          }\n        }\n      ],\n      \"pageType\": \"PAGE_TYPE_CANVAS\",\n      \"layoutVersion\": \"GRID_V1\"\n    },\n    {\n      \"name\": \"e92376df\",\n      \"displayName\": \"Global Filters\",\n      \"pageType\": \"PAGE_TYPE_GLOBAL_FILTERS\",\n      \"layoutVersion\": \"GRID_V1\"\n    }\n  ],\n  \"uiSettings\": {\n    \"theme\": {\n      \"widgetHeaderAlignment\": \"ALIGNMENT_UNSPECIFIED\"\n    },\n    \"applyModeEnabled\": false\n  }\n}\n",
