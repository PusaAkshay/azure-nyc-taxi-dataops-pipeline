{
  "datasets": [
    {
      "name": "6b29efba",
      "displayName": "Summary of New York City Taxi Trip Metrics",
      "queryLines": [
        "SELECT \r\n",
        "    COUNT(*) AS total_trips,\r\n",
        "    ROUND(SUM(total_amount), 2) AS total_revenue,\r\n",
        "    ROUND(AVG(trip_duration_mins), 2) AS avg_trip_duration,\r\n",
        "    ROUND(AVG(tip_percentage), 2) AS avg_tip_pct\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "8cdeb6f5",
      "displayName": "Taxi Trip Counts by Pickup Hour Category",
      "queryLines": [
        "SELECT \r\n",
        "    pickup_hour_category,\r\n",
        "    COUNT(*) AS trips\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "GROUP BY pickup_hour_category\r\n",
        "ORDER BY trips DESC;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "43fa2edb",
      "displayName": "Hourly Taxi Ride Totals by Pickup Time",
      "queryLines": [
        "SELECT \r\n",
        "    pickup_hour,\r\n",
        "    COUNT(*) AS trips\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "GROUP BY pickup_hour\r\n",
        "ORDER BY pickup_hour;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "73fe762a",
      "displayName": "Taxi Payment Category Revenue Summary",
      "queryLines": [
        "SELECT \r\n",
        "    payment_category,\r\n",
        "    ROUND(SUM(total_amount), 2) AS revenue\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "GROUP BY payment_category;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "68f1eb9a",
      "displayName": "Taxi Trip Distance Summary by Category",
      "queryLines": [
        "SELECT \r\n",
        "    trip_distance_category,\r\n",
        "    COUNT(*) AS trips\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "GROUP BY trip_distance_category;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "f9e3ba9e",
      "displayName": "Average Taxi Cost Per Mile by Distance Category",
      "queryLines": [
        "SELECT \r\n",
        "    trip_distance_category,\r\n",
        "    ROUND(AVG(cost_per_mile), 2) AS avg_cost_per_mile\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "GROUP BY trip_distance_category;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "03c139d1",
      "displayName": "Taxi Trip Summary with Duration Amount and Distance Categories",
      "queryLines": [
        "SELECT \r\n",
        "    trip_duration_mins,\r\n",
        "    total_amount,\r\n",
        "    trip_distance_category\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "LIMIT 10000;"
      ],
      "catalog": "nyctaxi",
      "schema": "taxi_db"
    },
    {
      "name": "19ea59c9",
      "displayName": "Average Taxi Tip Percentage by Payment Method",
      "queryLines": [
        "SELECT \r\n",
        "    payment_category,\r\n",
        "    ROUND(AVG(tip_percentage), 2) AS avg_tip\r\n",
        "FROM nyctaxi.taxi_db.gold_taxi_trips\r\n",
        "GROUP BY payment_category;"
      ]
    }
  ],
